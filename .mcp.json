{
  "mcpServers": {
    "playwright": {
      "type": "local",
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@latest",
        "--headless",
        "--browser",
        "chromium",
        "--output-dir",
        ".playwright-mcp"
      ],
      "tools": ["*"]
    }
  }
}
